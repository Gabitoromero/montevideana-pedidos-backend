# ============================================
# CONFIGURACIÓN DE ENTORNO
# ============================================
# Este archivo es una PLANTILLA. Copia este archivo a .env y ajusta los valores según tu entorno.
# 
# Para desarrollo:   cp .env.example .env  (y configura con valores locales)
# Para producción:   Configura con valores de producción en el servidor
#
# NUNCA commitees el archivo .env a Git (ya está en .gitignore)
# ============================================

# Entorno (development | production)
NODE_ENV=development

# Puerto del servidor
PORT=3001

# ============================================
# BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=montevideana_pedidos

# ============================================
# JWT (JSON Web Tokens)
# ============================================
# IMPORTANTE: Genera secretos seguros para producción
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# COOKIES (Autenticación Segura)
# ============================================
# Secret para firmar cookies (debe ser diferente de JWT_SECRET)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=your_cookie_secret_here_minimum_32_characters

# ============================================
# CHESS API
# ============================================
CHESS_API_URL=http://176.52.134.66:8080
CHESS_USER=your_chess_username
CHESS_PASSWORD=your_chess_password

# ============================================
# CORS (Control de Acceso)
# ============================================
# URLs del frontend que pueden acceder a esta API (separadas por comas)
# 
# Desarrollo:  http://localhost:5174,http://localhost:5173
# Producción:  https://pedidos.montevideana.com,https://www.pedidos.montevideana.com
ALLOWED_ORIGINS=http://localhost:5174

# ============================================
# DISCORD ALERTS (Opcional)
# ============================================
# Webhook para recibir alertas cuando el scheduler falla 3 veces consecutivas
# Dejar vacío si no quieres notificaciones
DISCORD_WEBHOOK_URL=

# ============================================
# SCHEDULER
# ============================================
# Controla si el scheduler de CHESS se ejecuta en este proceso
# true  = Desactivado (para workers del cluster)
# false = Activado (para proceso dedicado de scheduler)
DISABLE_SCHEDULER=false

# ============================================
# WAHA
# ============================================
WAHA_API_KEY=728f0f3da7824f8a8244c4977dc58b58

WAHA_DASHBOARD_USERNAME=
WAHA_DASHBOARD_PASSWORD=
WHATSAPP_SWAGGER_USERNAME=
WHATSAPP_SWAGGER_PASSWORD=

TELEFONO_DEVELOPER=telefono_de_desarrollador
WAHA_BASE_URL=http://localhost:3000
# Desarrollo:
WAHA_HOOK_URL=http://host.docker.internal:3001/api/waha/webhook
# Producción:
# WAHA_HOOK_URL=https://montheladoturnero.com/api/waha/webhook